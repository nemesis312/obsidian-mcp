{
  "projectName": "obsidian-mcp",
  "projectType": "auto",
  "agent": "claude",
  "defaultRole": "orchestrator",
  "defaultStack": "Auto-detect from run goal and repository context",
  "modelByPhase": {
    "design": "openai/gpt-5",
    "execute": "openai/gpt-5",
    "explore": "openai/gpt-5",
    "orchestrator": "openai/gpt-5",
    "plan": "openai/gpt-5",
    "prd": "openai/gpt-5",
    "report": "openai/gpt-5",
    "spec": "openai/gpt-5",
    "tasks": "openai/gpt-5",
    "verify": "openai/gpt-5"
  },
  "modelProfile": "premium",
  "memoryEnabled": true,
  "autoSaveNextSteps": false,
  "autoSubagents": true,
  "autoIncident": true,
  "autoIncidentCreateIssue": false,
  "preferredTemplateByRole": null,
  "allowedCommands": [
    "go",
    "git",
    "make",
    "goreleaser",
    "golangci-lint"
  ],
  "execTimeout": 300,
  "storage": {
    "primary": "file",
    "keepLocalArtifacts": true
  }
}